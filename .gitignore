# Deny by default
*

# Keep repo metadata/docs
!.gitignore
!README.md

# Allow selected pi config/resources
!.pi/
!.pi/agent/
!.pi/agent/settings.json
!.pi/agent/keybindings.json
!.pi/agent/models.json

!.pi/agent/extensions/
!.pi/agent/extensions/**/
!.pi/agent/extensions/**/*.ts
!.pi/agent/extensions/**/*.md
!.pi/agent/extensions/**/package.json
!.pi/agent/extensions/**/package-lock.json

!.pi/agent/prompts/
!.pi/agent/prompts/**/
!.pi/agent/prompts/**/*.md
!.pi/agent/skills/
!.pi/agent/skills/**/
!.pi/agent/skills/**/*.md
!.pi/agent/themes/
!.pi/agent/themes/**/
!.pi/agent/themes/**/*.json

# Always ignore sensitive/generated data
.pi/agent/auth.json
.pi/agent/sessions/**
.pi/agent/git/**
.pi/agent/bin/**
.pi/agent/pi-debug.log
.pi/agent/extensions/**/node_modules/**
.pi/agent/**/*.env*
