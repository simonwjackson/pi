# Deny by default
*

# Keep repo metadata/docs
!.gitignore
!README.md

# Allow selected pi config/resources (.pi)
!.pi/
!.pi/agent/
!.pi/agent/settings.json
!.pi/agent/keybindings.json
!.pi/agent/models.json

!.pi/agent/extensions/
!.pi/agent/extensions/**/
!.pi/agent/extensions/**/*.ts
!.pi/agent/extensions/**/*.md
!.pi/agent/extensions/**/package.json
!.pi/agent/extensions/**/bun.lock

!.pi/agent/prompts/
!.pi/agent/prompts/**/
!.pi/agent/prompts/**/*.md

!.pi/agent/skills/
!.pi/agent/skills/**

!.pi/agent/themes/
!.pi/agent/themes/**/
!.pi/agent/themes/**/*.json

# Allow selected agent config/resources (repo-local)
!agent/
!agent/settings.json
!agent/keybindings.json
!agent/models.json

!agent/extensions/
!agent/extensions/**/
!agent/extensions/**/*.ts
!agent/extensions/**/*.md
!agent/extensions/**/package.json
!agent/extensions/**/bun.lock

!agent/prompts/
!agent/prompts/**/
!agent/prompts/**/*.md

!agent/skills/
!agent/skills/**

!agent/themes/
!agent/themes/**/
!agent/themes/**/*.json

# Allow local Pi packages
!packages/
!packages/**/
!packages/**
packages/**/node_modules/**
packages/**/*.env*

# Always ignore sensitive/generated data
.pi/agent/auth.json
.pi/agent/sessions/**
.pi/agent/git/**
.pi/agent/bin/**
.pi/agent/pi-debug.log
.pi/agent/extensions/**/node_modules/**
.pi/agent/**/*.env*

agent/auth.json
agent/sessions/**
agent/git/**
agent/bin/**
agent/pi-debug.log
agent/extensions/**/node_modules/**
agent/**/*.env*

# Allow packages directory
!packages/
!packages/**/
!packages/**/*.ts
!packages/**/*.md
!packages/**/*.json
!packages/**/*.lock
!packages/**/*.nix

# Local backups
.backup-*/
/packages/pi-thinking/node_modules
/packages/agent-browser/result
